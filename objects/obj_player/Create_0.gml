// Creating an instance variable for the player hp
hp = 200
max_hp = 200

// Player animation will not play while they are still
image_speed = 0

// Initializing image angle so the player shoots in the right direction when they spawn
current_image_angle = 0

// Starting alarm[0] for the spit projectiles
alarm[0] = spit_cooldown

// Starting alarm[1] for the tongue attacks
alarm[1] = tongue_cooldown